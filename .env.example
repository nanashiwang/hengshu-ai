# 完整高级配置示例；NAS/Compose 首次部署优先用 .env.nas.example，业务接入项可部署后在后台「部署设置」填写。
# ── 数据库（与 docker-compose.yml 保持一致，统一用 DATABASE_URL）──
DATABASE_URL=postgres://payload:payload@localhost:5433/gewu

# ── Payload 密钥（生产务必改成强随机值：openssl rand -hex 32）──
PAYLOAD_SECRET=CHANGE_ME_DEV_SECRET

# ── 站点地址 ──
# SERVER_URL 供服务端 sitemap/robots/manifest/device auth 运行时读取；NEXT_PUBLIC_* 仅给客户端/兼容用
SERVER_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ── 媒体上传目录 ──
# 本地开发留空即可（回退到 public/media）；容器部署由 docker-compose 注入 /app/media（挂持久卷）
MEDIA_DIR=

# ── seed 首管/测试邀请 ──
# 生产 seed 若系统无管理员，必须显式提供 12 位以上强密码；开发未填会生成一次性随机密码并打印到控制台
SEED_ADMIN_EMAIL=admin@gewu.example
SEED_ADMIN_PASSWORD=
# 生产默认不创建固定 WELCOME1；确需临时测试才显式设 1
SEED_CREATE_WELCOME_CODE=

# ── Redis（运行分布式限流；生产平台代付缺失/不可用会 fail-closed）──
REDIS_URL=redis://localhost:6380

# ── 模型网关（OpenAI 兼容网关）。留空则 Skill 运行自动走 mock 回退 ──
MODEL_GATEWAY_BASE_URL=
MODEL_GATEWAY_KEY=
MODEL_GATEWAY_DEFAULT_MODEL=deepseek-chat

# ── 运行护栏（总纲 6a+6l）──
# 平台代付(用户未绑 Key 走 MODEL_GATEWAY_KEY)仅限已备案国产模型白名单；逗号分隔覆盖默认表，留空用默认，显式配置不可解析为空
# 默认: deepseek-chat,deepseek-reasoner,qwen-plus,qwen-turbo,qwen-max,glm-4,glm-4-flash,kimi-k2,moonshot-v1-8k
APPROVED_PLATFORM_MODELS=
# 每用户每分钟真实调用上限（默认 12）
RUN_RATE_LIMIT_PER_MIN=
# 每用户 10 分钟充值码尝试上限（默认 10；生产缺 Redis 时资金入口 fail-closed）
RECHARGE_ATTEMPT_LIMIT_PER_10MIN=
# 发布即评测队列：每轮最多处理多少 Skill、每个 Skill 最多真实调用多少次、指定评测模型(可空)
BENCHMARK_QUEUE_MAX_JOBS=
BENCHMARK_MAX_ATTEMPTS_PER_SKILL=
BENCHMARK_MODELS=
# Runner Bearer token 有效期天数（默认 90）
RUNNER_TOKEN_TTL_DAYS=
# 生产默认不接受旧明文 Runner token；仅迁移窗口临时设 1
ALLOW_LEGACY_RUNNER_TOKEN_AUTH=

# ── 反女巫：可信反代层数（生产 Nginx 等 append XFF 时设 1）──
TRUSTED_PROXY_COUNT=

# ── New API 管理 API（阶段2 变现；留空=stub 模式，变现闭环本地可跑通）──
# QuantumNous/new-api：鉴权=Authorization:<系统访问令牌> + New-Api-User:<平台账号数字ID>
# 注意：这里填 New API 后台「系统访问令牌/access token」，不是模型调用用的 sk-* Key。
NEWAPI_ADMIN_BASE_URL=
NEWAPI_ADMIN_KEY=
NEWAPI_ADMIN_USER_ID=
# Authorization 是否加 Bearer 前缀(源码默认不加；你的部署改过则设 1)
NEWAPI_AUTH_BEARER=
# 1 credit = 多少 quota（new-api QuotaPerUnit=500000/$1；按你售价校准，见 newapiAdmin 注释）
NEWAPI_CREDIT_TO_QUOTA=
# 子令牌分组(低价/受限分组)；生产留空会阻断，除非显式确认默认分组安全
NEWAPI_SUB_GROUP=
# 仅当已确认 New API 默认分组就是低价/受限分组时设 1；否则不要绕过 NEWAPI_SUB_GROUP
ALLOW_DEFAULT_NEWAPI_SUB_GROUP=
# 子令牌滚动 TTL 天数（默认 7；生产必须在 1-365 内，禁止永不过期）
NEWAPI_SUB_TOKEN_TTL_DAYS=
# 旧单一毛利率(0-1)：仅 local 估算或 dry-run 对照；newapi 真值默认优先用 /api/log other 实际倍率精算，缺失时回退 /api/pricing
NEWAPI_MARGIN_RATE=
# 旧按模型毛利率：仅 dry-run 对照；真钱写回不再依赖手填倍率
NEWAPI_MODEL_MARGIN_RATES=
# New API /api/log 消费与本地 credit consume 的最大容忍漂移(分)；留空=5% 或至少 2 分
NEWAPI_RECONCILE_TOLERANCE_CENTS=
# 逐用户对账漂移 JSONL 导出路径；必须以 .jsonl 结尾且不能是软链接；留空写入 .reconcile-reports/newapi-drift-YYYY-MM.jsonl（已 gitignore，原子写入，权限 0600）
NEWAPI_RECONCILE_DRIFT_REPORT_PATH=
# 用量来源：newapi=读取 /api/log token 真值，优先结合日志 other 实际倍率精算，缺失时回退 /api/pricing+/api/status；local=用本平台 consume 流水估算
NEWAPI_USAGE_SOURCE=newapi
# New API 日志口径：admin=/api/log；self=/api/log/self；auto=admin 不通时退 self（平台子令牌都在 NEWAPI_ADMIN_USER_ID 下时推荐）
NEWAPI_LOG_SCOPE=auto
# local 估算写回兑换池的硬确认；仅在已书面确认毛利率/配额口径时设 1，默认不允许开兑换
ALLOW_LOCAL_MARGIN_EXCHANGE=
# 小额真钱闭环校准：仅用于 npm run worker:calibrate-newapi -- --apply；必须用 calib- 前缀临时 ID，避免覆盖真实用户子令牌
NEWAPI_CALIBRATE_USER_ID=
NEWAPI_CALIBRATE_CREDITS=1
NEWAPI_CALIBRATE_MODEL=deepseek-chat

# manifest 签名私钥（ed25519 PKCS8 base64），用 npm run keygen 生成；留空则不签名
GEWU_SIGNING_KEY=

# ── 生产备份门禁（上线前必须真实完成；preflight 会阻断未确认项）──
# 已确认 pgdata+media 备份加密，且加密密钥不在同一服务器
BACKUP_ENCRYPTION_CONFIRMED=
# 已确认备份离机保存（对象存储/异地机器/离线介质等）
BACKUP_OFFSITE_CONFIRMED=
# 最近一次恢复演练日期（YYYY-MM-DD）；超过 35 天会警告
BACKUP_RESTORE_DRILL_AT=
