# ── 数据库（与 docker-compose.yml 保持一致，统一用 DATABASE_URL）──
DATABASE_URL=postgres://payload:payload@localhost:5433/skillhub

# ── Payload 密钥（生产务必改成强随机值：openssl rand -hex 32）──
PAYLOAD_SECRET=CHANGE_ME_DEV_SECRET

# ── 站点地址 ──
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ── 媒体上传目录 ──
# 本地开发留空即可（回退到 public/media）；容器部署由 docker-compose 注入 /app/media（挂持久卷）
MEDIA_DIR=

# ── Redis（Worker / 缓存 / 队列，后续使用）──
REDIS_URL=redis://localhost:6380

# ── 模型网关（OpenAI 兼容网关）。留空则 Skill 运行自动走 mock 回退 ──
MODEL_GATEWAY_BASE_URL=
MODEL_GATEWAY_KEY=
MODEL_GATEWAY_DEFAULT_MODEL=deepseek-chat

# manifest 签名私钥（ed25519 PKCS8 base64），用 npm run keygen 生成；留空则不签名
HENGSHU_SIGNING_KEY=
