{
  "name": "gewu",
  "version": "0.1.0",
  "description": "格物 — AI Skill 的可信与兼容控制平面",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "node scripts/clear-next.mjs && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "seed": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/index.ts",
    "migrate:spec-v1": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/migrate-spec-v1.ts",
    "artifacts:backfill": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/backfill-artifacts.ts",
    "seed:rules": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/contribution-rules.ts",
    "keygen": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/keygen.ts",
    "worker:skillrank": "cross-env NODE_OPTIONS=--no-deprecation tsx src/worker/recompute-skillrank.ts",
    "worker:backfill-passports": "cross-env NODE_OPTIONS=--no-deprecation tsx src/worker/backfill-passports.ts",
    "worker:refresh-model-profiles": "cross-env NODE_OPTIONS=--no-deprecation tsx src/worker/refresh-model-profiles.ts",
    "worker:backfill-compat-model-profiles": "cross-env NODE_OPTIONS=--no-deprecation tsx src/worker/backfill-compat-model-profiles.ts",
    "worker:cluster-failures": "cross-env NODE_OPTIONS=--no-deprecation tsx src/worker/cluster-failures.ts",
    "worker:reconcile": "cross-env NODE_OPTIONS=--no-deprecation tsx src/worker/reconcile-ledger.ts",
    "worker:benchmark": "cross-env NODE_OPTIONS=--no-deprecation tsx src/worker/benchmark.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/lint-guardrails.ts",
    "typecheck": "tsc --noEmit",
    "runner": "node runner/gewu.mjs",
    "worker:reconcile-newapi": "cross-env NODE_OPTIONS=--no-deprecation tsx src/worker/reconcile-newapi.ts",
    "worker:plan-newapi-drift": "cross-env NODE_OPTIONS=--no-deprecation tsx src/worker/plan-newapi-drift-actions.ts",
    "worker:migrate-secrets": "cross-env NODE_OPTIONS=--no-deprecation tsx src/worker/migrate-secrets.ts",
    "worker:newapi-probe": "cross-env NODE_OPTIONS=--no-deprecation tsx src/worker/probe-newapi.ts",
    "worker:calibrate-newapi": "cross-env NODE_OPTIONS=--no-deprecation tsx src/worker/calibrate-newapi.ts",
    "worker:sync-newapi-quota": "cross-env NODE_OPTIONS=--no-deprecation tsx src/worker/sync-newapi-quota.ts",
    "worker:backfill-register-credit": "cross-env NODE_OPTIONS=--no-deprecation tsx src/worker/backfill-register-credit.ts",
    "worker:preflight-production": "cross-env NODE_OPTIONS=--no-deprecation tsx src/worker/preflight-production.ts",
    "worker:export-score-anchors": "cross-env NODE_OPTIONS=--no-deprecation tsx src/worker/export-score-anchors.ts",
    "worker:verify-score-anchors": "cross-env NODE_OPTIONS=--no-deprecation tsx src/worker/verify-score-anchors.ts",
    "worker:export-evidence-anchors": "cross-env NODE_OPTIONS=--no-deprecation tsx src/worker/export-evidence-anchors.ts",
    "worker:verify-evidence-anchors": "cross-env NODE_OPTIONS=--no-deprecation tsx src/worker/verify-evidence-anchors.ts",
    "worker:benchmark-queue": "cross-env NODE_OPTIONS=--no-deprecation tsx src/worker/benchmark-queue.ts",
    "worker:import-skill-sources": "cross-env NODE_OPTIONS=--no-deprecation tsx src/worker/import-skill-sources.ts",
    "worker:preflight-private": "cross-env NODE_OPTIONS=--no-deprecation tsx src/worker/preflight-private-deploy.ts",
    "worker:sync-skill-sources": "cross-env IMPORT_SYNC=1 NODE_OPTIONS=--no-deprecation tsx src/worker/import-skill-sources.ts",
    "worker:reverify-queue": "cross-env NODE_OPTIONS=--no-deprecation tsx src/worker/reverify-queue.ts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.86.0",
    "@payloadcms/next": "3.86.0",
    "@payloadcms/richtext-lexical": "3.86.0",
    "@payloadcms/ui": "3.86.0",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "graphql": "^16.8.1",
    "next": "16.2.6",
    "payload": "3.86.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "redis": "^6.1.0",
    "sharp": "0.34.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.19.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "5.7.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "monaco-editor": {
      "dompurify": "3.4.12"
    }
  },
  "engines": {
    "node": ">=22 <23"
  }
}
