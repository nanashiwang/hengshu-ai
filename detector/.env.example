# Copy to .env and fill in your values
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7

# Public brand/runtime configuration
XIANCE_SITE_URL=http://localhost:8765
# Set this to the public repository before deployment (required by AGPL).
XIANCE_SOURCE_URL=
# Optional. Leave empty to disable analytics.
XIANCE_ANALYTICS_ID=
# Hosted deployments reject localhost/private targets by default. Enable only
# for a trusted self-hosted instance that intentionally tests LAN relays.
XIANCE_ALLOW_PRIVATE_TARGETS=0
XIANCE_JOBS_DIR=./web_data/jobs
XIANCE_WISHLIST_PATH=./web_data/wishlist.txt
